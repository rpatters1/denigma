PROJECT_NAME           = "denigma"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@CMAKE_BINARY_DIR@/docs/api"
INPUT                  = "@CMAKE_SOURCE_DIR@/include" "@CMAKE_SOURCE_DIR@/docs/mainpage.md"
USE_MDFILE_AS_MAINPAGE = "@CMAKE_SOURCE_DIR@/docs/mainpage.md"
RECURSIVE              = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
SEARCHENGINE           = YES

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

MARKDOWN_SUPPORT       = YES
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_AS_ERROR          = NO

FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = "@CMAKE_SOURCE_DIR@"
